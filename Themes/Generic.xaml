    <Style TargetType="{x:Type control:LEDDisplay}">
        <Setter Property="Width" Value="250"/>
        <Setter Property="Height" Value="120"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type control:LEDDisplay}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Grid rows are now properly sized based on LabelToDisplayRatio -->
                            <RowDefinition Height="{Binding LabelToDisplayRatio, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource DoubleToGridLengthConverter}}"/>
                            <RowDefinition Height="{Binding LabelToDisplayRatio, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource InverseRatioToGridLengthConverter}}"/>
                        </Grid.RowDefinitions>

                        <!-- Label Box -->
                        <Border Grid.Row="0" 
                                BorderBrush="{TemplateBinding LabelBorderBrush}" 
                                BorderThickness="{Binding ScaleFactor, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ScaleToThicknessConverter}}"
                                Background="{TemplateBinding LabelBackground}">
                            <TextBlock Text="{TemplateBinding LabelText}" 
                                       FontWeight="Bold"
                                       FontSize="{Binding LabelFontSize, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ScaleFontSizeConverter}}"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="{Binding ScaleFactor, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ScaleToMarginConverter}}"/>
                        </Border>

                        <!-- Display Box -->
                        <Border Grid.Row="1" 
                                BorderBrush="{TemplateBinding LabelBorderBrush}" 
                                BorderThickness="{Binding ScaleFactor, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ScaleToThicknessConverter}}"
                                Background="{TemplateBinding DisplayBackground}">
                            <TextBlock Text="{TemplateBinding FormattedText}" 
                                       FontFamily="Consolas, Courier New, Monospace"
                                       FontWeight="Bold"
                                       FontSize="{Binding BaseFontSize, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ScaleFontSizeConverter}}"
                                       Foreground="{TemplateBinding DisplayForeground}"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type control:ToggleImageControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type control:ToggleImageControl}">
                    <Image x:Name="PART_Image">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" 
                                    Value="{Binding OffImageSource, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <!-- 关闭状态：默认暗淡发光 -->
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#404060" BlurRadius="5" 
                                                      ShadowDepth="0" Opacity="0.30"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <!-- 开启状态：切换图片 + 青色发光 -->
                                    <DataTrigger Binding="{Binding IsToggled, 
                                             RelativeSource={RelativeSource TemplatedParent}}" 
                                             Value="True">
                                        <Setter Property="Source" 
                                            Value="{Binding OnImageSource, RelativeSource={RelativeSource TemplatedParent}}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#00C8E0" BlurRadius="12" 
                                                              ShadowDepth="0" Opacity="0.85"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
